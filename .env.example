# QR Attend — local secrets (optional)
# Copy to `.env` and fill in. Values here override fallbacks in conn/config.php.
# Do not commit `.env` with real credentials.

APP_NAME=QR Attend
# APP_URL=http://localhost/attendance

# Database
DB_HOST=localhost
DB_NAME=attendance
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# EgoSMS API (https://www.egosms.co)
EGOSMS_ENABLED=true
EGOSMS_USERNAME=YOUR_EGOSMS_USERNAME
EGOSMS_PASSWORD=YOUR_EGOSMS_PASSWORD
EGOSMS_SENDER=QRAttend
EGOSMS_ENDPOINT=https://www.egosms.co/api/v1/plain/
EGOSMS_PRIORITY=0
EGOSMS_TIMEOUT=20

# SMS behaviour
SMS_NOTIFY_PARENT_ON_ATTENDANCE=true
# SMS_ATTENDANCE_TEMPLATE={student} has been marked present at {time} ({course}). - {app}

# Auth / password policy
AUTH_USERNAME_MIN=3
AUTH_USERNAME_MAX=50
AUTH_PASSWORD_MIN=8
AUTH_PASSWORD_MAX=72
AUTH_PASSWORD_REQUIRE_LETTER=true
AUTH_PASSWORD_REQUIRE_NUMBER=true
AUTH_PASSWORD_REQUIRE_SPECIAL=false
AUTH_API_TOKEN_BYTES=32
AUTH_ALLOW_TOKEN_IN_POST=true
AUTH_SESSION_NAME=QRATTENDSESSID

# Password reset OTP
PASSWORD_RESET_OTP_TTL=15
PASSWORD_RESET_OTP_LENGTH=6

# CORS (usually leave false for same-origin web + Flutter native)
CORS_ENABLED=false
CORS_ALLOWED_ORIGINS=*
